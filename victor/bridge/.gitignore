# C++ extension build outputs
extension/build/
extension/gen/
extension/godot-cpp
extension/*.os
extension/src/*.o
extension/src/*.os
extension/.sconsign.dblite

# Built extension binaries land in the project (keep the dir, not the libs)
project/bin/*.so
project/bin/*.dylib
project/bin/*.dll
project/bin/*.wasm

# Godot editor cache
project/.godot/

# Gradle build template installed by the Android CI export
project/android/

# Third-party godot_wry addon fetched by tools/fetch-godot-wry.sh (desktop
# native webview for VUI.webview) — a build-time dependency, never committed
project/addons/godot_wry/

# Android plugin gradle build outputs (bridge/android/webview)
android/webview/build/
android/webview/.gradle/

# CI export outputs
build/
